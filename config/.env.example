# ============================================================
# Polymarket Trading Bot — Environment Variables
# Copy this file to .env in the project root and fill in values
# ============================================================

# --- Polymarket CLOB ---
# Get from https://polymarket.com → Profile → API keys
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY=          # Your Polygon wallet private key (hex, no 0x prefix)

# --- News Sources ---
# Free tier: https://newsapi.org/register (100 req/day)
NEWSAPI_KEY=
# Free tier: https://gnews.io (100 req/day backup)
GNEWS_API_KEY=

# --- Anthropic Claude ---
# Get from https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# --- Account ---
# Set this to your actual Polymarket balance in USD
ACCOUNT_EQUITY_USD=1000.0

# --- Database (optional override) ---
# Default: SQLite at data/polymarket.db
# For PostgreSQL: postgresql+psycopg2://user:pass@localhost:5432/polymarket
# DATABASE_URL=sqlite:///data/polymarket.db

# --- Telegram Notifications ---
# Create a bot via @BotFather on Telegram, then get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Risk Overrides (optional) ---
# MAX_TRADE_RISK_PCT=0.01
# KELLY_FRACTION=0.25
# MAX_DAILY_RISK_PCT=0.05
# MIN_EV_THRESHOLD=0.05
# SCAN_INTERVAL_MINUTES=15
